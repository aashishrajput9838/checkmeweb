rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // TEMPORARY DEBUGGING RULES - PERMISSIVE READS
    
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Allow self-registration
      
      match /attendance_history/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }
    
    match /notices/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /mess_menu/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /daily_overrides/{date} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /monthly_surveys/{surveyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      
      match /votes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }
    
    match /inventory/{itemId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /attendance/{date} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /food_analytics/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
