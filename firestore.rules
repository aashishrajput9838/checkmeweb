rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Robust helper to check roles - handles non-existent user documents gracefully
    function hasRole(role) {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
             get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == role;
    }
    
    function isAdmin() {
      return hasRole('admin');
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.token.email == userId);
      
      match /attendance_history/{docId} {
        allow read: if request.auth != null && (request.auth.token.email == userId || isAdmin() || hasRole('warden'));
        allow write: if isAdmin() || hasRole('warden');
      }
    }
    
    match /notices/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || hasRole('warden');
    }
    
    match /mess_menu/{document} {
      allow read: if request.auth != null;
      allow write: if hasRole('representative') || isAdmin() || hasRole('staff');
    }
    
    match /daily_overrides/{date} {
      allow read: if request.auth != null;
      allow write: if hasRole('staff') || isAdmin();
    }
    
    match /monthly_surveys/{surveyId} {
      allow read: if request.auth != null;
      allow write: if hasRole('staff') || isAdmin();
      
      match /votes/{userId} {
        allow read: if request.auth != null && (request.auth.token.email == userId || isAdmin() || hasRole('staff'));
        allow write: if request.auth != null && request.auth.token.email == userId;
      }
    }
    
    match /inventory/{itemId} {
      allow read: if request.auth != null && (hasRole('staff') || isAdmin());
      allow write: if hasRole('staff') || isAdmin();
    }
    
    match /attendance/{date} {
      allow read: if request.auth != null && (hasRole('warden') || isAdmin());
      allow write: if hasRole('warden') || isAdmin();
    }
    
    match /food_analytics/{document} {
      allow read: if request.auth != null;
      allow write: if hasRole('staff') || isAdmin() || hasRole('warden');
    }
  }
}
